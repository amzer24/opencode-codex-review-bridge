{
  "name": "opencode-codex-review",
  "version": "1.0.0",
  "description": "Automatic Codex code review for OpenCode — reviews plans, responses, and diffs",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": ["opencode", "codex", "code-review", "plugin"],
  "author": "Lee Leckenby",
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/sdk": ">=0.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.3"
  }
}
